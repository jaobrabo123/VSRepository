{
  "name": "vsrepo",
  "version": "1.0.4",
  "description": "Uma biblioteca de repositório virtual para Prisma",
  "main": "./VSRepository/index.js",
  "types": "./VSRepository/index.d.ts",
  "exports": {
    ".": {
      "types": "./VSRepository/index.d.ts",
      "import": "./VSRepository/index.js",
      "require": "./VSRepository/index.js"
    },
    "./VSRepository": {
      "types": "./VSRepository/VSRepository.d.ts",
      "import": "./VSRepository/VSRepository.js",
      "require": "./VSRepository/VSRepository.js"
    },
    "./VSRepoError": {
      "types": "./VSRepository/VSRepoError.d.ts",
      "import": "./VSRepository/VSRepoError.js",
      "require": "./VSRepository/VSRepoError.js"
    }
  },
  "type": "module",
  "files": [
    "VSRepository",
    "scripts"
  ],
  "bin": {
    "vsrepo": "./scripts/configure-prisma-import.mjs",
    "vsrepo-configure-prisma-import": "./scripts/configure-prisma-import.mjs"
  },
  "scripts": {
    "vsrepo": "node ./scripts/configure-prisma-import.mjs",
    "configure:prisma-import": "node ./scripts/configure-prisma-import.mjs"
  },
  "keywords": [
    "prisma",
    "repository",
    "orm",
    "typescript",
    "vsrepo",
    "vsrepository"
  ],
  "author": "João Pedro Azevedo",
  "license": "MIT",
  "peerDependencies": {
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}