{
  "name": "vsrepo",
  "version": "1.2.6",
  "description": "Uma biblioteca de repository pattern para Prisma",
  "homepage": "https://github.com/jaobrabo123/VSRepository#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaobrabo123/VSRepository.git"
  },
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./src/index.js"
    },
    "./VSRepository": {
      "types": "./src/VSRepository.d.ts",
      "import": "./src/VSRepository.ts",
      "require": "./src/VSRepository.ts"
    },
    "./VSRepoError": {
      "types": "./src/VSRepoError.d.ts",
      "import": "./src/VSRepoError.ts",
      "require": "./src/VSRepoError.ts"
    }
  },
  "type": "module",
  "files": [
    "src",
    "scripts"
  ],
  "bin": {
    "vsrepo": "scripts/configure-prisma-import.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "vsrepo": "node ./scripts/configure-prisma-import.mjs"
  },
  "keywords": [
    "prisma",
    "repository",
    "orm",
    "typescript",
    "vsrepo",
    "vsrepository",
    "jparepository"
  ],
  "author": "João Pedro Azevedo Freire Mecenas",
  "license": "MIT",
  "peerDependencies": {
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "deepmerge": "^4.3.1",
    "zod": "^4.4.3"
  }
}
