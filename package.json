{
  "name": "vsrepo",
  "version": "1.3.2",
  "description": "A repository pattern library for Prisma",
  "homepage": "https://github.com/jaobrabo123/VSRepository#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaobrabo123/VSRepository.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./VSRepository": {
      "types": "./dist/VSRepository.d.ts",
      "import": "./dist/VSRepository.js",
      "require": "./dist/VSRepository.js"
    },
    "./VSRepoError": {
      "types": "./dist/VSRepoError.d.ts",
      "import": "./dist/VSRepoError.js",
      "require": "./dist/VSRepoError.js"
    }
  },
  "type": "commonjs",
  "files": [
    "dist",
    "scripts"
  ],
  "bin": {
    "vsrepo": "scripts/configure-prisma-import.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "vsrepo": "node ./scripts/configure-prisma-import.mjs",
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-types.mjs",
    "prepack": "pnpm build"
  },
  "keywords": [
    "prisma",
    "repository",
    "orm",
    "typescript",
    "vsrepo",
    "vsrepository",
    "jparepository"
  ],
  "author": "João Pedro Azevedo Freire Mecenas",
  "license": "MIT",
  "peerDependencies": {
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "deepmerge": "^4.3.1",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  }
}
