generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ROLES {
  VIEWER
  MODIFIER
  CIENTIST
  ALL
}

enum SECTORS {
  HUMAN_RESOURCES
  FINANCE
  MARKETING
  SALES
  INFORMATION_TECHNOLOGY
}

enum USER_TYPE {
  ADMIN
  COMMON
}

model User {
  id         String      @id @default(cuid(2))
  name       String      @db.VarChar(150)
  email      String      @unique @db.VarChar(254)
  password   String?     @db.VarChar(255)
  active     Boolean     @default(true)
  userType   USER_TYPE
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  admin      Admin?
  commonUser CommonUser?

  @@map("user")
}

model CommonUser {
  id        String   @id @default(cuid(2))
  biography String?  @db.VarChar(300)
  birthDate DateTime @map("birth_date")
  image     String   @db.VarChar(255)
  followers Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post[]

  @@map("common_user_profile")
}

model Admin {
  id        String   @id @default(cuid(2))
  role      ROLES[]
  sector    SECTORS
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin")
}

model Post {
  id           String     @id @default(cuid(2))
  title        String     @db.VarChar(200)
  content      String     @db.Text
  publicated   Boolean    @default(false)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  commonUserId String     @map("common_user_id")
  commonUser   CommonUser @relation(fields: [commonUserId], references: [id], onDelete: Cascade)
  postTags     PostTag[]

  @@map("post")
}

model PostTag {
  id          String   @id @default(cuid(2))
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  posts       Post[]

  @@map("post_tag")
}
