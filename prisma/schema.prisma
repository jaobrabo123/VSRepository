generator client {
    provider        = "prisma-client"
    output          = "../src/generated/prisma"
    previewFeatures = ["postgresqlExtensions"]
}

datasource db {
    provider = "postgresql"
}

model usuario {
    id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    nome            String    @db.VarChar(150)
    idade           Int
    email           String    @unique @db.VarChar(254)
    ativo           Boolean   @default(true)
    dataCriacao     DateTime  @default(now()) @map("data_criacao") @db.Timestamptz(6)
    dataAtualizacao DateTime  @default(now()) @updatedAt @map("data_atualizacao") @db.Timestamptz(6)
    produtos        produto[]
}

model produto {
    id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    nome            String   @db.VarChar(100)
    preco           Decimal  @db.Decimal(12, 2)
    codigo          String   @db.VarChar(100)
    usuarioId       String   @map("usuario_id") @db.Uuid
    usuario         usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
    dataCriacao     DateTime @default(now()) @map("data_criacao") @db.Timestamptz(6)
    dataAtualizacao DateTime @default(now()) @updatedAt @map("data_atualizacao") @db.Timestamptz(6)

    @@unique([usuarioId, codigo])
}
